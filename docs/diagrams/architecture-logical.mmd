flowchart LR
  client["Cliente"]
  gateway["API Gateway<br/>entrada publica"]
  game["game-service<br/>regras da run"]
  catalog["catalog-service<br/>cartas e inimigos"]
  worker["game-outbox-worker<br/>entrega assincrona"]
  ranking["ranking-service<br/>ranking idempotente"]

  subgraph database["MongoDB Replica Set rs0"]
    direction TB
    gameState[("runs, battles,<br/>rewards")]
    outbox[("outboxevents")]
    rankingState[("rankings,<br/>processedruns")]
  end

  client --> gateway --> game
  gateway -->|"consulta"| ranking
  game -.->|"consulta"| catalog
  game -->|"1. atualiza"| gameState
  game -->|"2. mesma transacao"| outbox
  outbox -->|"3. claim"| worker
  worker -->|"4. POST interno"| ranking
  ranking -->|"5. processa uma vez"| rankingState

  classDef entry fill:#0f5132,stroke:#0f5132,stroke-width:2px,color:#ffffff;
  classDef service fill:#ecfdf3,stroke:#17803d,stroke-width:1px,color:#0f172a;
  classDef worker fill:#f5f3ff,stroke:#7c3aed,stroke-width:2px,color:#0f172a;
  classDef storage fill:#fff7ed,stroke:#ea580c,stroke-width:2px,color:#0f172a;

  class client,gateway entry;
  class game,catalog,ranking service;
  class worker worker;
  class gameState,outbox,rankingState storage;

  style database fill:#ffffff,stroke:#cbd5e1,stroke-width:1px,color:#0f172a
