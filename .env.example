NODE_ENV=development

# Gateway
API_GATEWAY_HOST_PORT=3000
GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://auth-service:3001
CATALOG_SERVICE_URL=http://catalog-service:3002
GAME_SERVICE_URL=http://game-service:3003
RANKING_SERVICE_URL=http://ranking-service:3004
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
UPSTREAM_TIMEOUT_MS=5000
INTERNAL_SERVICE_SECRET=troque_por_um_segredo_interno_longo

# Auth service
AUTH_SERVICE_PORT=3001
MONGO_URI=mongodb://mongodb:27017/roguelike?replicaSet=rs0
JWT_SECRET=troque_por_um_segredo_jwt_longo
JWT_ISSUER=roguelike-api
JWT_AUDIENCE=roguelike-client
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=10

# Admin seed
ADMIN_SEED_NAME=Admin
ADMIN_SEED_EMAIL=admin@email.com
ADMIN_SEED_PASSWORD=troque_por_uma_senha_admin_forte

# Catalog service
CATALOG_SERVICE_PORT=3002

# Game service
GAME_SERVICE_PORT=3003
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BASE_DELAY_MS=1000
OUTBOX_MAX_DELAY_MS=60000
OUTBOX_LOCK_TIMEOUT_MS=30000
OUTBOX_HTTP_TIMEOUT_MS=5000
OUTBOX_METRICS_PORT=3005

# Ranking service
RANKING_SERVICE_PORT=3004

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3005
GRAFANA_USER=admin
GRAFANA_PASSWORD=troque_por_uma_senha_grafana_forte
